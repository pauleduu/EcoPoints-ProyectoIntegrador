<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#344E41"
    android:orientation="vertical">

    <TextView
        android:id="@+id/textView3"
        android:layout_width="match_parent"
        android:layout_height="49dp"
        android:layout_gravity="bottom"
        android:background="#DAD7CD"
        android:fontFamily="@font/inria_serif"
        android:gravity="center"
        android:text="EcoPoints"
        android:textColor="#000000"
        android:textSize="25sp"/>

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="425dp"
        android:layout_height="116dp"
        android:layout_gravity="center"
        android:background="#DAD7CD"
        app:srcCompat="@drawable/logo"/>

    <View
        android:id="@+id/view"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:background="#344E41"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:fontFamily="@font/inria_serif"
        android:text="Registro de Usuario"
        android:textColor="#DAD7CD"
        android:textSize="25sp"
        tools:ignore="HardcodedText"/>

    <View
        android:id="@+id/view2"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:background="#344E41"/>

    <TextView
        android:id="@+id/textView4"
        android:layout_width="388dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:fontFamily="@font/roboto"
        android:text="Nombre(s):"
        android:textColor="#DAD7CD"/>

    <EditText
        android:id="@+id/TextV_nombre"
        android:layout_width="388dp"
        android:layout_height="35dp"
        android:layout_gravity="center"
        android:background="#FFFFFF"
        android:hint="Nombre(s)"
        android:inputType="text"
        android:textColorHint="#696968"
        android:textColor="#696968"/>

    <View
        android:id="@+id/view3"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="#344E41"/>

    <TextView
        android:id="@+id/textView5"
        android:layout_width="388dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:fontFamily="@font/roboto"
        android:text="Apellido(s):"
        android:textColor="#DAD7CD"/>

    <EditText
        android:id="@+id/TextV_apellido"
        android:layout_width="388dp"
        android:layout_height="35dp"
        android:layout_gravity="center"
        android:background="#FFFFFF"
        android:hint="Apellido(s)"
        android:inputType="text"
        android:textColorHint="#696968"
        android:textColor="#696968"/>

    <View
        android:id="@+id/view4"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:background="#344E41"/>

    <TextView
        android:id="@+id/textView6"
        android:layout_width="388dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:fontFamily="@font/roboto"
        android:text="Codigo UDG:"
        android:textColor="#DAD7CD"/>

    <EditText
        android:id="@+id/TextV_codigo"
        android:layout_width="388dp"
        android:layout_height="35dp"
        android:layout_gravity="center"
        android:background="#FFFFFF"
        android:hint="Codigo UDG"
        android:inputType="number"
        android:maxLength="9"
        android:textColorHint="#696968"
        android:textColor="#696968"/>

    <View
        android:id="@+id/view5"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="#344E41"/>

    <TextView
        android:id="@+id/textView7"
        android:layout_width="388dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:fontFamily="@font/roboto"
        android:text="Contraseña:"
        android:textColor="#DAD7CD"/>

    <EditText
        android:id="@+id/TextV_contraseña"
        android:layout_width="388dp"
        android:layout_height="35dp"
        android:layout_gravity="center"
        android:background="#FFFFFF"
        android:hint="Contraseña"
        android:inputType="textPassword"
        android:textColorHint="#696968"
        android:textColor="#696968"/>

    <View
        android:id="@+id/view6"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="#344E41"/>

    <TextView
        android:id="@+id/textView8"
        android:layout_width="388dp"
        android:layout_height="24dp"
        android:layout_gravity="center"
        android:fontFamily="@font/roboto"
        android:text="Confirmar Contraseña:"
        android:textColor="#DAD7CD"/>

    <EditText
        android:id="@+id/TextV_confirmar"
        android:layout_width="388dp"
        android:layout_height="35dp"
        android:layout_gravity="center"
        android:background="#FFFFFF"
        android:hint="Confirmar Contraseña"
        android:inputType="textPassword"
        android:textColorHint="#696968"
        android:textColor="#696968"/>

    <CheckBox
        android:id="@+id/checkbox_mostrar_registro"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Mostrar contraseñas"
        android:textColor="#DAD7CD"
        android:layout_gravity="center_horizontal"/>


    <View
        android:id="@+id/view7"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:background="#344E41"/>

    <Button
        android:id="@+id/btn_registrar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:backgroundTint="#588157"
        android:text="Registrarse"
        android:fontFamily="@font/roboto"
        android:textColor="#000000"/>

</LinearLayout>